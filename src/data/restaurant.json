  "testimonials": [
    {
      "name": "Sarah M.",
      "rating": 5,
      "text": "Absolutely love this place! The butter chicken is the best I've had outside of India. The staff is incredibly friendly and the atmosphere is warm and inviting. A hidden gem in Maynard!",
      "source": "Google"
    },
    {
      "name": "James R.",
      "rating": 5,
      "text": "We've been coming here for years and it never disappoints. The lunch specials are an incredible value. The naan bread is always fresh and the portions are generous. Highly recommend!",
      "source": "Google"
    },
    {
      "name": "Priya K.",
      "rating": 4,
      "text": "As someone who grew up eating Indian food, I can say this place is authentic. The flavors remind me of home. The vegetarian options are extensive and delicious. Will keep coming back!",
      "source": "Yelp"
    },
    {
      "name": "Michael T.",
      "rating": 5,
      "text": "Catered our wedding reception and the food was phenomenal. Our guests are still talking about the samosas and chicken tikka masala. Professional service and incredible food!",
      "source": "Google"
    }
  ],
