  "faq": [
    {
      "question": "Do you offer vegetarian and vegan options?",
      "answer": "Yes! We have an extensive vegetarian menu with over 20 dishes. Many of our dishes can be prepared vegan upon request. Please inform your server about any dietary restrictions and our chefs will be happy to accommodate."
    },
    {
      "question": "Do you take reservations?",
      "answer": "We accept reservations for parties of 6 or more. For smaller parties, we operate on a first-come, first-served basis. Call us at (978) 897-9227 to make a reservation."
    },
    {
      "question": "Do you offer delivery?",
      "answer": "We offer takeout and you can place orders by calling us at (978) 897-9227. Online ordering will be available soon on our website."
    },
    {
      "question": "What are your hours?",
      "answer": "We are open 7 days a week from 11:30 AM to 9:00 PM. We are open on all holidays unless otherwise noted on our social media pages."
    },
    {
      "question": "Do you cater events?",
      "answer": "Absolutely! We cater weddings, corporate events, birthday parties, and more. Contact us through our catering form or call us directly to discuss your event needs. A minimum order of $150 applies with at least 48 hours advance notice."
    },
    {
      "question": "Do you have parking available?",
      "answer": "Yes, there is free street parking available on Main Street and in the public parking lot behind the building. The parking lot can be accessed from both Main Street and Nason Street."
